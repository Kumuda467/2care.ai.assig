# 2care.ai - Voice AI Agent Backend Configuration

PORT=8000
DATABASE_URL=sqlite:///./healthcare.db

# (Optional) For production agent reasoning and real tool-calling
# If left blank, the backend falls back to the intelligent Local Agent Engine
OPENAI_API_KEY=

# (Optional) For Redis-backed session memory with TTL and horizontal scaling
# If left blank, SQL-based memory or local memory will be used
REDIS_URL=
